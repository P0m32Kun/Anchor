# 功能测试 / 真实外网验收 — 被动搜索引擎凭证
# 复制后填写密钥（勿提交 git）:
#   cp functional-test.env.example functional-test.env
#
# 各 functional-test-*.sh 会自动加载 functional-test.env；
# 也可手动注入 Anchor:
#   bash scripts/inject-engine-credentials.sh

# --- Anchor API（与 .env 中 ANCHOR_API_TOKEN 一致时可省略）---
# ANCHOR_API_BASE=http://localhost:17421
# ANCHOR_API_TOKEN=test-e2e-token

# --- FOFA（company 目标展开；extra 一般为注册邮箱）---
FOFA_API_KEY=
FOFA_EMAIL=

# --- 奇安信 Hunter ---
HUNTER_API_KEY=

# --- 360 Quake ---
QUAKE_API_KEY=

# --- 真实外网脚本 optional ---
# FT_DOMAIN=lixiang.com
# FT_COMPANY=北京车励行信息技术有限公司
# FT_PORT_RANGE=80,443

# --- 工具调用校验（verify-tool-calls.sh --profile 默认值）---
# FT_EXPECT_TOOLS=naabu,httpx,dnsx
# FT_OPTIONAL_TOOLS=nuclei,subfinder
