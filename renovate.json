    },
    {
      "customType": "regex",
      "description": "gau",
      "fileMatch": ["Dockerfile\\.worker-base$"],
      "matchStrings": ["ARG\\s+GAU_VERSION=(?<currentValue>\\S+)"],
      "depNameTemplate": "lc/gau",
      "datasourceTemplate": "github-releases",
      "versioningTemplate": "semver"
    },
    {
      "customType": "regex",
      "description": "spoor",
      "fileMatch": ["Dockerfile\\.worker-base$"],
      "matchStrings": ["ARG\\s+SPOOR_VERSION=(?<currentValue>\\S+)"],
      "depNameTemplate": "P0m32Kun/Spoor",
