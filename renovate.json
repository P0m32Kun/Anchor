{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:base"],
  "customManagers": [
    {
      "customType": "regex",
      "description": "subfinder",
      "fileMatch": ["Dockerfile\\.worker-base$"],
      "matchStrings": ["ARG\\s+SUBFINDER_VERSION=(?<currentValue>\\S+)"],
      "depNameTemplate": "projectdiscovery/subfinder",
      "datasourceTemplate": "github-releases",
      "versioningTemplate": "semver"
    },
    {
      "customType": "regex",
      "description": "naabu",
      "fileMatch": ["Dockerfile\\.worker-base$"],
      "matchStrings": ["ARG\\s+NAABU_VERSION=(?<currentValue>\\S+)"],
