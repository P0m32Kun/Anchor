  ],
  "packageRules": [
    {
      "matchFileNames": ["Dockerfile.worker-base"],
      "matchUpdateTypes": ["minor", "patch"],
      "automerge": true,
      "automergeType": "pr",
      "groupName": "security-tools"
    },
    {
      "matchFileNames": ["Dockerfile.worker-base"],
      "matchUpdateTypes": ["major"],
      "automerge": false,
      "groupName": "security-tools-major"
    }
  ]
}
