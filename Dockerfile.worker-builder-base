# Anchor Worker Builder Base Image
# 预装 Go 构建环境和模块依赖，极少更新
# 构建: docker build -f Dockerfile.worker-builder-base -t anchor-worker-builder-base:latest .

FROM golang:1.26-bookworm

RUN apt-get update && apt-get install -y --no-install-recommends git gcc libsqlite3-dev \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /build
# goproxy.cn TLS 不稳定，退回到官方代理
ENV GOPROXY=https://proxy.golang.org,direct
ENV GOSUMDB=off

COPY go.mod go.sum ./
RUN go mod download
