<!DOCTYPE html>
<html lang="zh">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>CyberOS Red Team Workbench</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        /* 自定义科技感发光特效与背景 */
        body {
            background-color: #0b1120;
            background-image: 
                radial-gradient(circle at 50% 50%, rgba(15, 23, 42, 0) 0%, rgba(11, 17, 32, 1) 100%),
                url('https://www.transparenttextures.com/patterns/stardust.png'); /* 模拟星空/节点背景 */
            color: #94a3b8;
        }
        
        .glass-panel {
            background: rgba(30, 41, 59, 0.4);
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
            border: 1px solid rgba(71, 85, 105, 0.4);
        }

        .glow-blue {
            border-color: rgba(56, 189, 248, 0.6);
            box-shadow: 0 0 20px rgba(56, 189, 248, 0.15), inset 0 0 10px rgba(56, 189, 248, 0.05);
        }

        .glow-red {
            border-color: rgba(248, 113, 113, 0.6);
            box-shadow: 0 0 20px rgba(248, 113, 113, 0.15), inset 0 0 10px rgba(248, 113, 113, 0.05);
        }

        .text-glow-blue { text-shadow: 0 0 10px rgba(56, 189, 248, 0.5); }
        .text-glow-red { text-shadow: 0 0 10px rgba(248, 113, 113, 0.5); }

        /* 模拟扫描线动画 */
        .scan-line {
            position: absolute;
            top: 0; left: 0; right: 0; height: 2px;
            background: linear-gradient(to right, transparent, rgba(56, 189, 248, 0.8), transparent);
            animation: scan 3s linear infinite;
            opacity: 0.5;
        }
        @keyframes scan {
            0% { transform: translateY(-100%); }
            100% { transform: translateY(200px); }
        }
    </style>
</head>
<body class="min-h-screen font-sans antialiased overflow-x-hidden p-4 md:p-8">

    <!-- 顶层导航栏 -->
    <header class="flex items-center justify-between mb-8 pb-4 border-b border-slate-700/50">
        <div class="flex items-center gap-8">
            <div class="flex items-center gap-3">
                <!-- 盾牌 Logo (SVG) -->
                <svg class="w-8 h-8 text-blue-400 drop-shadow-[0_0_8px_rgba(96,165,250,0.5)]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 22V2"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 12h16"></path></svg>
                <div>
                    <h1 class="text-white font-bold tracking-wider leading-tight">CYBEROS</h1>
                    <p class="text-xs text-slate-400 tracking-widest">RED TEAM WORKBENCH</p>
                </div>
            </div>
            
            <nav class="hidden md:flex gap-6 text-sm font-medium">
                <a href="#" class="text-blue-400 border-b-2 border-blue-400 pb-1">DASHBOARD</a>
                <a href="#" class="hover:text-white transition-colors">PROJECTS</a>
                <a href="#" class="hover:text-white transition-colors">ASSETS</a>
                <a href="#" class="hover:text-white transition-colors">FINDINGS</a>
                <a href="#" class="hover:text-white transition-colors">REPORTS</a>
            </nav>
        </div>

        <div class="flex items-center gap-4">
            <div class="relative glass-panel rounded-full px-4 py-1.5 flex items-center">
                <svg class="w-4 h-4 text-slate-400 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
                <input type="text" placeholder="Search..." class="bg-transparent border-none outline-none text-sm text-white placeholder-slate-500 w-32 focus:w-48 transition-all">
            </div>
            <div class="w-8 h-8 rounded-full bg-slate-700 border border-slate-500 overflow-hidden">
                <img src="https://i.pravatar.cc/100?img=11" alt="User" class="w-full h-full object-cover">
            </div>
        </div>
    </header>

    <!-- 顶部数据看板网格 -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-6">
        
        <!-- 卡片 1: Active Operations (蓝色高光) -->
        <div class="glass-panel rounded-xl p-5 relative overflow-hidden glow-blue">
            <div class="scan-line"></div>
            <div class="flex justify-between items-start mb-2">
                <h3 class="text-xs font-semibold text-slate-300 tracking-wider">ACTIVE OPERATIONS</h3>
                <svg class="w-4 h-4 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path></svg>
            </div>
            <div class="text-4xl font-bold text-white mb-1 text-glow-blue">12</div>
            <!-- 模拟折线图 -->
            <svg class="w-full h-10 text-blue-400 my-2 drop-shadow-[0_0_5px_rgba(56,189,248,0.8)]" viewBox="0 0 100 30" preserveAspectRatio="none"><path d="M0,20 Q10,10 20,25 T40,15 T60,20 T80,5 T100,10" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"></path></svg>
            <p class="text-xs text-blue-400">4 High-Priority Targets</p>
        </div>

        <!-- 卡片 2: Total Assets -->
        <div class="glass-panel rounded-xl p-5">
            <div class="flex justify-between items-start mb-2">
                <h3 class="text-xs font-semibold text-slate-300 tracking-wider">TOTAL ASSETS</h3>
                <svg class="w-4 h-4 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"></path></svg>
            </div>
            <div class="flex items-center justify-between">
                <div>
                    <div class="text-4xl font-bold text-white mb-1">1,450</div>
                    <p class="text-xs text-red-400">350 Vulnerable Nodes</p>
                </div>
                <!-- 模拟饼图 -->
                <div class="w-12 h-12 rounded-full border-4 border-blue-500/30 border-t-blue-400 drop-shadow-[0_0_8px_rgba(56,189,248,0.4)]"></div>
            </div>
        </div>

        <!-- 卡片 3: Recent Findings -->
        <div class="glass-panel rounded-xl p-5 glow-blue relative overflow-hidden">
            <div class="flex justify-between items-start mb-2">
                <h3 class="text-xs font-semibold text-slate-300 tracking-wider">RECENT FINDINGS</h3>
                <svg class="w-4 h-4 text-yellow-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path></svg>
            </div>
            <div class="flex items-end justify-between">
                <div>
                    <div class="text-4xl font-bold text-white mb-1">55</div>
                    <p class="text-xs text-blue-400">24 Confirmed</p>
                </div>
                <!-- 模拟柱状图 -->
                <div class="flex items-end gap-1 h-10">
                    <div class="w-1.5 bg-blue-500/50 h-3 rounded-t"></div>
                    <div class="w-1.5 bg-blue-500/50 h-5 rounded-t"></div>
                    <div class="w-1.5 bg-blue-400 h-8 rounded-t drop-shadow-[0_0_5px_rgba(56,189,248,0.8)]"></div>
                    <div class="w-1.5 bg-blue-500/50 h-4 rounded-t"></div>
                    <div class="w-1.5 bg-blue-500/50 h-6 rounded-t"></div>
                </div>
            </div>
        </div>

        <!-- 卡片 4: Key Vulnerabilities (红色高光) -->
        <div class="glass-panel rounded-xl p-5 relative overflow-hidden glow-red">
            <div class="flex justify-between items-start mb-2">
                <h3 class="text-xs font-semibold text-slate-300 tracking-wider">KEY VULNERABILITIES</h3>
                <svg class="w-4 h-4 text-red-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
            </div>
            <div class="flex items-center justify-between">
                <div>
                    <div class="text-4xl font-bold text-white mb-1 text-glow-red">8</div>
                    <p class="text-xs text-red-400">8 Requires Exploitation</p>
                </div>
                <div class="w-10 h-10 text-red-500 drop-shadow-[0_0_8px_rgba(248,113,113,0.6)]">
                    <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path></svg>
                </div>
            </div>
        </div>
    </div>

    <!-- 操作按钮组 -->
    <div class="flex gap-4 mb-6">
        <button class="bg-blue-600 hover:bg-blue-500 text-white text-sm font-medium py-2 px-6 rounded-lg shadow-[0_0_15px_rgba(37,99,235,0.4)] transition-all flex items-center gap-2 border border-blue-400/50">
            <span>+</span> NEW OPERATION
        </button>
        <button class="glass-panel hover:bg-slate-700/50 text-slate-200 text-sm font-medium py-2 px-6 rounded-lg transition-all">
            IMPORT DATA
        </button>
        <button class="glass-panel hover:bg-slate-700/50 text-slate-200 text-sm font-medium py-2 px-6 rounded-lg transition-all">
            VIEW REPORTS
        </button>
    </div>

    <!-- 底部详情区域网格 -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
        
        <!-- 左侧：活动流 -->
        <div class="glass-panel rounded-xl p-6">
            <h3 class="text-sm font-semibold text-white mb-6 tracking-wider">RECENT ACTIVITY FEED</h3>
            <div class="space-y-6 relative before:absolute before:inset-0 before:ml-5 before:-translate-x-px md:before:mx-auto md:before:translate-x-0 before:h-full before:w-0.5 before:bg-gradient-to-b before:from-transparent before:via-slate-700 before:to-transparent">
                
                <!-- 动态项 1 -->
                <div class="relative flex items-center justify-between md:justify-normal md:odd:flex-row-reverse group is-active">
                    <div class="flex items-center justify-center w-10 h-10 rounded-full border border-slate-700 bg-slate-800 text-slate-400 shrink-0 md:order-1 md:group-odd:-translate-x-1/2 md:group-even:translate-x-1/2 shadow-[0_0_10px_rgba(0,0,0,0.5)] z-10">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                    </div>
                    <div class="w-[calc(100%-4rem)] md:w-[calc(50%-2.5rem)] p-4 rounded border border-slate-700/50 bg-slate-800/30">
                        <div class="flex items-center justify-between mb-1">
                            <span class="font-medium text-slate-300 text-sm">Scan 'Web App v3' completed</span>
                            <time class="text-xs text-slate-500">14:32</time>
                        </div>
                        <div class="text-xs text-slate-400">Found <span class="text-red-400 font-semibold drop-shadow-[0_0_2px_rgba(248,113,113,0.8)]">1 critical vulnerability</span>.</div>
                    </div>
                </div>

                <!-- 动态项 2 -->
                <div class="relative flex items-center justify-between md:justify-normal md:odd:flex-row-reverse group">
                    <div class="flex items-center justify-center w-10 h-10 rounded-full border border-slate-700 bg-slate-800 text-slate-400 shrink-0 md:order-1 md:group-odd:-translate-x-1/2 md:group-even:translate-x-1/2 shadow-[0_0_10px_rgba(0,0,0,0.5)] z-10">
                        <svg class="w-4 h-4 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
                    </div>
                    <div class="w-[calc(100%-4rem)] md:w-[calc(50%-2.5rem)] p-4 rounded border border-slate-700/50 bg-slate-800/30">
                        <div class="flex items-center justify-between mb-1">
                            <span class="font-medium text-slate-300 text-sm">Started new scan</span>
                            <time class="text-xs text-slate-500">14:15</time>
                        </div>
                        <div class="text-xs text-slate-400">'Internal Network' target initialized.</div>
                    </div>
                </div>

            </div>
        </div>

        <!-- 右侧：漏洞表格 -->
        <div class="glass-panel rounded-xl p-6">
            <div class="flex justify-between items-center mb-6">
                <h3 class="text-sm font-semibold text-white tracking-wider">KEY FINDINGS BREAKDOWN</h3>
                <svg class="w-5 h-5 text-slate-400 cursor-pointer hover:text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 4a1 1 0 011-1h16a1 1 0 011 1v2.586a1 1 0 01-.293.707l-6.414 6.414a1 1 0 00-.293.707V17l-4 4v-6.586a1 1 0 00-.293-.707L3.293 7.293A1 1 0 013 6.586V4z"></path></svg>
            </div>
            
            <div class="overflow-x-auto">
                <table class="w-full text-left text-sm">
                    <thead>
                        <tr class="border-b border-slate-700/50 text-slate-400">
                            <th class="pb-3 font-medium">Finding Name</th>
                            <th class="pb-3 font-medium">Severity</th>
                            <th class="pb-3 font-medium">Asset</th>
                            <th class="pb-3 font-medium">Status</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-slate-700/50">
                        <tr class="hover:bg-slate-800/30 transition-colors">
                            <td class="py-3 text-slate-200">SQL Injection</td>
                            <td class="py-3">
                                <span class="px-2 py-1 rounded text-xs font-medium bg-red-900/50 text-red-400 border border-red-800">Critical</span>
                            </td>
                            <td class="py-3 text-slate-400">App Server</td>
                            <td class="py-3">
                                <span class="px-2 py-1 rounded text-xs font-medium bg-emerald-900/30 text-emerald-400 border border-emerald-800/50">New</span>
                            </td>
                        </tr>
                        <tr class="hover:bg-slate-800/30 transition-colors">
                            <td class="py-3 text-slate-200">Cross-Site Scripting</td>
                            <td class="py-3">
                                <span class="px-2 py-1 rounded text-xs font-medium bg-orange-900/50 text-orange-400 border border-orange-800">High</span>
                            </td>
                            <td class="py-3 text-slate-400">Main Site</td>
                            <td class="py-3">
                                <span class="px-2 py-1 rounded text-xs font-medium bg-slate-800 text-slate-300 border border-slate-700">Verifying</span>
                            </td>
                        </tr>
                        <tr class="hover:bg-slate-800/30 transition-colors">
                            <td class="py-3 text-slate-200">Unsecured API Key</td>
                            <td class="py-3">
                                <span class="px-2 py-1 rounded text-xs font-medium bg-yellow-900/50 text-yellow-400 border border-yellow-800">Medium</span>
                            </td>
                            <td class="py-3 text-slate-400">Cloud Config</td>
                            <td class="py-3">
                                <span class="px-2 py-1 rounded text-xs font-medium bg-blue-900/30 text-blue-400 border border-blue-800/50">Needs Review</span>
                            </td>
                        </tr>
                        <tr class="hover:bg-slate-800/30 transition-colors">
                            <td class="py-3 text-slate-200">Weak Password Policy</td>
                            <td class="py-3">
                                <span class="px-2 py-1 rounded text-xs font-medium bg-green-900/30 text-green-400 border border-green-800/50">Low</span>
                            </td>
                            <td class="py-3 text-slate-400">Database</td>
                            <td class="py-3">
                                <span class="px-2 py-1 rounded text-xs font-medium bg-slate-800/50 text-slate-500 border border-slate-700/50">Closed</span>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>

    </div>

</body>
</html>